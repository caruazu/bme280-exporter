#!/usr/bin/make -f

# Build is NATIVE: the devcontainer, the homologação VM and the Pi are all
# arm64 (aarch64). The stock `gcc` already emits aarch64 — no cross-compiler,
# no architecture.mk, no DEB_HOST_* juggling.

%:
	dh $@ --with=installsysusers

# The Makefile has no install target; dh_install handles placement.
override_dh_auto_install:

override_dh_install:
	dh_install --sourcedir=.

override_dh_builddeb:
	dh_builddeb --destdir=bin
